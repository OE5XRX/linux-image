# OE5XRX Station — A/B rootfs layout for x86-64 (QEMU/dev).
#
# Mirrors the RPi A/B concept with GRUB-EFI as bootloader.
# The kernel lives INSIDE each rootfs (/boot); GRUB loads it from the active
# root_${boot_part} slot, so OTA (which rewrites only the rootfs) updates the
# kernel atomically with its modules. The ESP holds only GRUB + config.
#
# Layout (GPT, 4 partitions):
#   1 efi       (FAT, 128 MB, ESP)  — GRUB-EFI + grub.cfg + grubenv
#   2 root_a    (ext4, 1024 MB)     — Rootfs A + kernel (read-only at runtime)
#   3 root_b    (ext4, 1024 MB)     — Rootfs B (OTA target, starts empty)
#   4 data      (ext4, 2048 MB)     — Persistent /var, overlay /etc, /home

bootloader --ptable=gpt --configfile=oe5xrx-grub.cfg

# --no-fstab-update: wic would otherwise inject a `/boot` fstab line by the FAT
# volume UUID, which is regenerated every build. OTA rewrites only the rootfs,
# so an OTA'd slot's baked UUID never matches the on-disk ESP → /boot times out
# → emergency mode → rollback. The image recipe adds a stable PARTLABEL=efi
# entry instead (see add_efi_fstab).
part /boot --source bootimg-efi --sourceparams="loader=grub-efi" --ondisk vda --fstype=vfat --label efi --active --align 4 --fixed-size 128 --no-fstab-update
part / --source rootfs --ondisk vda --fstype=ext4 --label root_a --fixed-size 1024 --align 4
part --ondisk vda --fstype=ext4 --label root_b --fixed-size 1024 --align 4
part --ondisk vda --fstype=ext4 --label data --fixed-size 2048 --align 4
